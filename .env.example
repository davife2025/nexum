# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Agent wallet private key (0x-prefixed hex)
# Leave blank to use an ephemeral wallet (generated per restart).
# Fund at https://faucet.gokite.ai for real on-chain attestations.
AGENT_PRIVATE_KEY=0x...

# ── Kite chain (defaults provided — no need to change) ────────────────────────
# KITE_RPC_TESTNET=https://rpc-testnet.gokite.ai/
# KITE_RPC_MAINNET=https://rpc.gokite.ai/
# KITE_CHAIN_ID_TESTNET=2368
# KITE_CHAIN_ID_MAINNET=2366
