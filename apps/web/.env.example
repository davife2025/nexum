# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: legacy local-wallet mode ───────────────────────────────────────
# Used for on-chain attestations always, and for x402 payment signing when
# no Kite Passport session is active. Leave blank for an ephemeral wallet
# that's regenerated on each server restart. Fund at https://faucet.gokite.ai
# to write real on-chain attestations.
AGENT_PRIVATE_KEY=0x...

# ── Optional: Kite Agent Passport ────────────────────────────────────────────
# When configured, the agent routes payments through a user-bound Passport
# session instead of the local wallet. Leave both blank to run in simulate
# mode (no real Passport backend; local mock for demos).
#
# Production:
#   KITE_PASSPORT_BASE_URL=https://api.agentpassport.ai
#   KITE_PASSPORT_API_KEY=kpass_live_...
#
# CLI agent only — pin to a specific session for non-interactive runs:
#   KITE_PASSPORT_SESSION_ID=sess_...
KITE_PASSPORT_BASE_URL=
KITE_PASSPORT_API_KEY=
KITE_PASSPORT_SESSION_ID=

# ── Kite chain (auto-configured — no need to change) ─────────────────────────
# KITE_RPC_TESTNET=https://rpc-testnet.gokite.ai/
# KITE_CHAIN_ID=2368

